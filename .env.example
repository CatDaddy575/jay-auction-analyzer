# BringATrailer Credentials
# IMPORTANT: Never commit .env file. Store actual credentials in C:\Users\info\passwords\credentials.md
# The .env file reads from vault via config system

BA_USERNAME=your-username
BA_PASSWORD=your-password

# Agent Configuration
JAY_MODE=monitor
# Modes: monitor (tracking only), analyze (+ intelligence), bid (+ auto-bidding)

# Notification Settings
ALERT_EMAIL=carsandcats1980s@protonmail.com
DEBUG_MODE=false

# Database
DB_PATH=./data/jay.db

# Browser
HEADLESS_BROWSER=true
BROWSER_TIMEOUT=30000
